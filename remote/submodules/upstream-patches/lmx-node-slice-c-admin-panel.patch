@@ -0,0 +1,93 @@
+'use strict';
+
+/**
+ * Runtime-mutable log-level filter for the broker's `log.*` helpers.
+ *
+ * This module is the Node sibling of the Rust port's
+ * `tracing_subscriber::reload::Handle<EnvFilter>` plumbing — it lets an
+ * operator change verbosity at runtime via `POST /admin/log` instead of
+ * having to set `LMX_LOG_LEVEL` and restart the broker process.
+ *
+ * The Rust runtime supports `RUST_LOG`-style per-target directives
+ * (`info,lmx=debug`); Node's `live-mutex` does not have that machinery
+ * and adding one for parity would be over-engineering. Instead this
+ * module exposes a simple ordered enum:
+ *
+ *   error < warn < info < debug
+ *
+ * with `error` always emitted (errors are never silenced) and any other
+ * level emitted iff `LEVEL_ORDER[level] <= LEVEL_ORDER[currentLevel]`.
+ *
+ * The `/admin/log` HTTP endpoint advertises the supported levels via
+ * `listLevels()` so the admin panel JS can render a `<select>` instead
+ * of a free-text input — that's the user-visible difference from the
+ * Rust admin panel, and the in-page comment + `runtime` field on the
+ * GET response document it explicitly.
+ */
+
+import {routineEnter} from './routine';
+
+export type LogLevel = 'error' | 'warn' | 'info' | 'debug';
+
+const LEVEL_ORDER: Record<LogLevel, number> = {
+    error: 0,
+    warn: 1,
+    info: 2,
+    debug: 3,
+};
+
+const VALID_LEVELS: readonly LogLevel[] = ['error', 'warn', 'info', 'debug'] as const;
+
+/// Current process-global log level. Initialised from `LMX_LOG_LEVEL`
+/// at module load (default `info`). Mutated by `setLogLevel`.
+let currentLevel: LogLevel = readEnvLevel();
+
+function readEnvLevel(): LogLevel {
+    const routineId = 'ddl-routine-readEnvLevel-Lq6';
+    routineEnter(routineId, 'log-level.readEnvLevel');
+    const raw = String(process.env.LMX_LOG_LEVEL || '').trim().toLowerCase();
+    return (VALID_LEVELS as readonly string[]).includes(raw)
+        ? (raw as LogLevel)
+        : 'info';
+}
+
+/// Read-only accessor for the current level. Returned by
+/// `GET /admin/log` so the admin panel can mark the active option.
+export function getLogLevel(): LogLevel {
+    return currentLevel;
+}
+
+/// Swap the live log level. Returns `{previous, current}` for audit
+/// logging (matches the shape of `setOtelEnabled`'s return). Throws
+/// if the requested level isn't one of `VALID_LEVELS`; the
+/// `/admin/log` POST handler maps that throw to a 400.
+export function setLogLevel(level: string): {previous: LogLevel; current: LogLevel} {
+    const routineId = 'ddl-routine-setLogLevel-Vt8';
+    routineEnter(routineId, 'log-level.setLogLevel');
+    const trimmed = String(level || '').trim().toLowerCase();
+    if (!(VALID_LEVELS as readonly string[]).includes(trimmed)) {
+        throw new Error(
+            `invalid log level "${level}"; expected one of ${VALID_LEVELS.join(', ')}`,
+        );
+    }
+    const previous = currentLevel;
+    currentLevel = trimmed as LogLevel;
+    process.stdout.write(
+        `lmx log: setLogLevel previous=${previous} next=${currentLevel}\n`,
+    );
+    return {previous, current: currentLevel};
+}
+
+/// Predicate consulted by the broker's `log.info` / `log.warn` /
+/// `log.debug` helpers to decide whether to format + emit a line.
+/// `log.error` short-circuits this check — errors are never silenced.
+export function levelEnabled(level: LogLevel): boolean {
+    return LEVEL_ORDER[level] <= LEVEL_ORDER[currentLevel];
+}
+
+/// Return the supported levels in increasing-verbosity order. Used by
+/// the admin panel HTML to populate the level `<select>` and by tests
+/// to assert the contract.
+export function listLevels(): readonly LogLevel[] {
+    return VALID_LEVELS;
+}
