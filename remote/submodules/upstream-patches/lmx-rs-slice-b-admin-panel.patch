+/// GET reflects boot-time defaults; POST flips one or both flags;
+/// follow-up GET reflects the new values. The response body always
+/// includes `tcp_quickack_supported` so the admin panel JS can
+/// disable the QUICKACK toggle on non-Linux builds.
+#[tokio::test]
+async fn admin_tcp_round_trip_flips_atomics() {
+    let (_, http_port) = start_server(false, true).await;
+    let port = http_port.unwrap();
+    let url_get = format!("http://127.0.0.1:{port}/admin/tcp");
+
+    let before = http_get_json_with_headers(
+        &url_get,
+        &[("x-admin-token", "all-dogs-go-to-heaven")],
+    )
+    .await;
+    assert_eq!(before["tcp_nodelay"], serde_json::Value::Bool(true));
+    assert_eq!(before["tcp_quickack"], serde_json::Value::Bool(true));
+    assert!(before["tcp_quickack_supported"].is_boolean());
+
+    // Flip both off via a single POST.
+    let body_bytes = serde_json::to_vec(&serde_json::json!({
+        "tcp_nodelay": false,
+        "tcp_quickack": false,
+    }))
+    .unwrap();
+    let head = format!(
+        "POST /admin/tcp HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw = head.into_bytes();
+    raw.extend_from_slice(&body_bytes);
+    let post_resp = http_send_raw("127.0.0.1", port, &raw).await;
+    assert!(
+        post_resp.starts_with("HTTP/1.1 200"),
+        "authed POST /admin/tcp should be 200; got: {post_resp:.200}",
+    );
+    let post_body = parse_json_body(&post_resp);
+    assert_eq!(post_body["previous"]["tcp_nodelay"], serde_json::Value::Bool(true));
+    assert_eq!(post_body["previous"]["tcp_quickack"], serde_json::Value::Bool(true));
+    assert_eq!(post_body["current"]["tcp_nodelay"], serde_json::Value::Bool(false));
+    assert_eq!(post_body["current"]["tcp_quickack"], serde_json::Value::Bool(false));
+
+    let after = http_get_json_with_headers(
+        &url_get,
+        &[("x-admin-token", "all-dogs-go-to-heaven")],
+    )
+    .await;
+    assert_eq!(after["tcp_nodelay"], serde_json::Value::Bool(false));
+    assert_eq!(after["tcp_quickack"], serde_json::Value::Bool(false));
+
+    // Flip back via a partial POST that only sets `tcp_nodelay` — the
+    // QUICKACK flag must stay at its current value (still `false`).
+    let body_bytes = serde_json::to_vec(&serde_json::json!({"tcp_nodelay": true})).unwrap();
+    let head = format!(
+        "POST /admin/tcp HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw_partial = head.into_bytes();
+    raw_partial.extend_from_slice(&body_bytes);
+    let partial = http_send_raw("127.0.0.1", port, &raw_partial).await;
+    assert!(partial.starts_with("HTTP/1.1 200"), "partial POST must be 200; got: {partial:.160}");
+    let partial_body = parse_json_body(&partial);
+    assert_eq!(partial_body["current"]["tcp_nodelay"], serde_json::Value::Bool(true));
+    assert_eq!(partial_body["current"]["tcp_quickack"], serde_json::Value::Bool(false));
+
+    // Restore prior steady state.
+    let body_bytes = serde_json::to_vec(&serde_json::json!({"tcp_quickack": true})).unwrap();
+    let head = format!(
+        "POST /admin/tcp HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw_restore = head.into_bytes();
+    raw_restore.extend_from_slice(&body_bytes);
+    let _ = http_send_raw("127.0.0.1", port, &raw_restore).await;
+}
