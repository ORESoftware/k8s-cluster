+
+    let body = serde_json::json!({"directives": target});
+    let body_bytes = serde_json::to_vec(&body).unwrap();
+    let req = format!(
+        "POST /admin/log HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw = req.into_bytes();
+    raw.extend_from_slice(&body_bytes);
+    let post_resp = http_send_raw("127.0.0.1", port, &raw).await;
+    assert!(
+        post_resp.starts_with("HTTP/1.1 200"),
+        "authed POST should be 200; got: {post_resp:.200}",
+    );
+    let post_body = parse_json_body(&post_resp);
+    assert_eq!(post_body["previous"], serde_json::Value::String(was.clone()));
+    assert_eq!(post_body["directives"], serde_json::Value::String(target.to_string()));
+
+    let after = http_get_json_with_headers(
+        &url_get,
+        &[("x-admin-token", "all-dogs-go-to-heaven")],
+    )
+    .await;
+    assert_eq!(after["directives"], serde_json::Value::String(target.to_string()));
+    assert_eq!(dd_rust_network_mutex::current_log_directives(), target);
+
+    // Restore the prior directives so we don't leak verbosity into
+    // other parallel tests.
+    let restore_body = serde_json::to_vec(&serde_json::json!({"directives": was})).unwrap();
+    let mut raw_restore = format!(
+        "POST /admin/log HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = restore_body.len(),
+    )
+    .into_bytes();
+    raw_restore.extend_from_slice(&restore_body);
+    let _ = http_send_raw("127.0.0.1", port, &raw_restore).await;
+}
+
+/// Bad bodies (empty, non-JSON, malformed directives) all map to 400.
+#[tokio::test]
+async fn admin_log_post_validates_body_and_directives() {
+    let _guard = LOG_DIRECTIVES_TEST_LOCK.lock().unwrap();
+    dd_rust_network_mutex::init_tracing();
+    let (_, http_port) = start_server(false, true).await;
+    let port = http_port.unwrap();
+
+    let no_body = http_send_raw(
+        "127.0.0.1",
+        port,
+        b"POST /admin/log HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Length: 0\r\nConnection: close\r\n\r\n",
+    )
+    .await;
+    assert!(
+        no_body.starts_with("HTTP/1.1 400") || no_body.starts_with("HTTP/1.1 415"),
+        "empty body must be rejected; got: {no_body:.160}",
+    );
+
+    // Empty `directives` string must be rejected by `set_log_directives`
+    // (we explicitly check for `trim().is_empty()`).
+    let body_bytes = serde_json::to_vec(&serde_json::json!({"directives": ""})).unwrap();
+    let head = format!(
+        "POST /admin/log HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw_empty = head.into_bytes();
+    raw_empty.extend_from_slice(&body_bytes);
+    let empty_resp = http_send_raw("127.0.0.1", port, &raw_empty).await;
+    assert!(
+        empty_resp.starts_with("HTTP/1.1 400"),
+        "empty directives string must be 400; got: {empty_resp:.160}",
+    );
+
+    // Body without the required `directives` key.
+    let body_bytes = b"{\"foo\":\"bar\"}";
+    let head = format!(
+        "POST /admin/log HTTP/1.1\r\nHost: 127.0.0.1\r\nx-admin-token: all-dogs-go-to-heaven\r\nContent-Type: application/json\r\nContent-Length: {len}\r\nConnection: close\r\n\r\n",
+        len = body_bytes.len(),
+    );
+    let mut raw_bad = head.into_bytes();
+    raw_bad.extend_from_slice(body_bytes);
+    let bad_resp = http_send_raw("127.0.0.1", port, &raw_bad).await;
+    assert!(
+        bad_resp.starts_with("HTTP/1.1 400"),
+        "missing `directives` key must be 400; got: {bad_resp:.160}",
+    );
+}
