+// ---- /admin/tcp runtime socket-tuning -------------------------------------
+
+/// Both methods of `/admin/tcp` require the shared-secret header.
+#[tokio::test]
+async fn admin_tcp_requires_shared_secret_header() {
+    let (_, http_port) = start_server(false, true).await;
+    let port = http_port.unwrap();
+
+    let resp_get = http_get_with_headers(&format!("http://127.0.0.1:{port}/admin/tcp"), &[]).await;
+    assert!(
+        resp_get.starts_with("HTTP/1.1 401"),
+        "unauthenticated GET /admin/tcp must be 401; got: {resp_get:.120}",
+    );
+
+    let resp_post = http_send_raw(
+        "127.0.0.1",
+        port,
+        // `{"tcp_nodelay":false}` is exactly 21 bytes.
+        b"POST /admin/tcp HTTP/1.1\r\nHost: 127.0.0.1\r\nContent-Type: application/json\r\nContent-Length: 21\r\nConnection: close\r\n\r\n{\"tcp_nodelay\":false}",
+    )
+    .await;
+    assert!(
+        resp_post.starts_with("HTTP/1.1 401"),
+        "unauthenticated POST /admin/tcp must be 401; got: {resp_post:.120}",
+    );
+}
