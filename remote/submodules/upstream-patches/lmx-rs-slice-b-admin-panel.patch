+/// `previous` value. Other tests in this file are fine to keep
+/// parallel; only the ones that flip directives need to coordinate.
+///
+/// Uses `std::sync::Mutex` (no new deps; const-constructible since Rust
+/// 1.63). We `.lock().unwrap()` the poison guard rather than wrapping
+/// in a panic-recovery layer because a poisoned lock here means a prior
+/// test panicked mid-flip — bubbling that up surfaces the underlying
+/// failure rather than hiding it behind a flaky-looking second test.
+static LOG_DIRECTIVES_TEST_LOCK: std::sync::Mutex<()> = std::sync::Mutex::new(());
