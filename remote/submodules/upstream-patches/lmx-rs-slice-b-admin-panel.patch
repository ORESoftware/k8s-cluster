+/// Empty body, non-JSON, and the "no fields set" body shape must all
+/// return 400 — the operator gets actionable feedback rather than a
+/// silent no-op.
+#[tokio::test]
+async fn admin_tcp_post_validates_body_shape() {
+    let (_, http_port) = start_server(false, true).await;
+    let port = http_port.unwrap();
+
+    let no_body = http_send_raw(
+        "127.0.0.1",
