{
  "name": "dd-dev-server",
  "version": "0.1.0",
  "description": "Long-lived HTTP server that spawns coding agents against a warm configured git checkout and streams events.",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "minikube:preflight": "node tests/minikube-preflight.mjs",
    "minikube:start": "pnpm run minikube:preflight && minikube start --driver=docker --cpus=${DD_MINIKUBE_CPUS:-4} --memory=${DD_MINIKUBE_MEMORY:-6144} --disk-size=${DD_MINIKUBE_DISK_SIZE:-40g}",
    "minikube:build": "bash -lc 'eval \"$(minikube docker-env)\" && DOCKER_BUILDKIT=1 docker build --secret id=github_deploy_key,src=\"${GH_DEPLOY_KEY_PATH:-$HOME/.ssh/id_ed25519}\" -t dd-dev-server-local:latest .'",
    "minikube:apply": "kubectl apply -f k8s/minikube-dev-server.yaml",
    "minikube:restart": "kubectl -n dd-dev-local rollout restart deployment/dd-dev-server-local",
    "minikube:port-forward": "kubectl -n dd-dev-local port-forward svc/dd-dev-server-local 8080:8080",
    "test:local-smoke": "pnpm run test:minikube-manifest && pnpm run test:thread-smoke && pnpm run test:thread-ui-smoke",
    "test:minikube-manifest": "node tests/minikube-manifest-smoke.mjs",
    "test:thread-smoke": "node tests/thread-smoke.mjs",
    "test:thread-ui-smoke": "node tests/thread-ui-smoke.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@aws-sdk/client-s3": "^3.658.0",
    "@openai/agents": "^0.9.1",
    "@supabase/supabase-js": "^2.86.2",
    "fastify": "^5.0.0",
    "rxjs": "^7.8.2",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.12.0"
}
