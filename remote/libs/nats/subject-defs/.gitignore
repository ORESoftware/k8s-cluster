# Generator-local ignores. These live alongside the generated artifacts so
# that `cargo build`, `gleam build`, `dart pub get`, `mvn package`, `go test`,
# etc. used to smoke-test the outputs don't add lockfiles or build trees to
# the commit. The top-level repo .gitignore already covers `target/`,
# `build/`, `node_modules/`, etc., so this file only adds the per-runtime
# artefacts those rules miss.
generated/rust/Cargo.lock
generated/go/go.sum
generated/dart/.dart_tool/
generated/dart/pubspec.lock
generated/jvm/target/
generated/erlang/_build/
generated/erlang/rebar.lock
