# HTTP server
BIND_ADDR=0.0.0.0
PORT=8111

# Logging: trace|debug|info|warn|error or full env_filter directives.
RUST_LOG=formal_methods_service=info,tower_http=info

# GitHub webhook secret (HMAC-SHA256). Required for the /webhook/github route
# to accept calls. Generate with `openssl rand -hex 32`.
GITHUB_WEBHOOK_SECRET=

# Optional GitHub token used for cloning private repos, listing PR files for
# the path filter, and posting commit-statuses back to the PR. When unset
# the analyzer runs in dry-run mode and only logs the result.
GITHUB_TOKEN=
GITHUB_API_BASE_URL=https://api.github.com

# Where transient PR checkouts are placed. Each analysis runs in a unique
# subdirectory.
WORKDIR_ROOT=/var/lib/dd-formal-methods-service/work

# Analyzer configuration: which manifest to check on the PR head commit.
# These are paths inside the cloned PR worktree.
CONTRACT_MANIFEST_PATH=packages/contract/Cargo.toml
CARGO_TEST_PACKAGE=om-core
CARGO_TEST_FEATURES=

# Concurrency bound for in-flight analyses.
MAX_CONCURRENT_ANALYSES=2

# Per-step process timeout in seconds.
ANALYZER_TIMEOUT_SECS=900

# ----------------------------------------------------------------------------
# Webhook hardening
# ----------------------------------------------------------------------------
# Allowlist of `owner/repo` slugs this service is willing to analyze. Empty
# or `*` means allow everything (safe defaults for local/dev; *do* set this
# in production). Each entry is exact-match or `owner/*` for an owner-wide
# wildcard. Case-insensitive.
FORMAL_METHODS_ALLOWED_REPOS=*

# Path-prefix filter on the PR's changed files. When set, only PRs that
# touch at least one file under one of these prefixes will be analyzed;
# all other PRs get a `success` commit-status with reason
# `no_contract_changes`. Empty means run on every PR.
FORMAL_METHODS_PATH_PREFIXES=

# Dedupe `X-GitHub-Delivery` IDs across this many recent webhooks so that
# GitHub's automatic retries on a slow handler do not trigger duplicate
# analyses. The TTL bounds how long a delivery ID is remembered.
DELIVERY_DEDUPE_CAPACITY=1024
DELIVERY_DEDUPE_TTL_SECS=3600

# Maximum number of changed-file pages to fetch from the GitHub API for the
# path-filter decision (100 entries per page). PRs larger than this cap are
# conservatively treated as in-scope.
MAX_PR_FILES_PAGES=3

# GitHub commit-status `context` string posted by the service. This is the
# name that branch-protection's "Require status checks to pass" rule
# matches on, so keep it stable across deployments of the same logical
# pipeline.
STATUS_CONTEXT=formal-methods/analysis

# ----------------------------------------------------------------------------
# Formal-methods step toggles. Each step self-skips when its tool isn't on
# PATH; toggling lets you cut total wall-clock time on a noisy PR. Accepts
# `true`/`false`/`1`/`0`/`yes`/`no` (case-insensitive).
# ----------------------------------------------------------------------------
FORMAL_METHODS_CARGO_CHECK_ENABLED=true
FORMAL_METHODS_CARGO_TEST_ENABLED=true
FORMAL_METHODS_PROPTEST_ENABLED=true
FORMAL_METHODS_KANI_ENABLED=true
FORMAL_METHODS_VERUS_ENABLED=true
FORMAL_METHODS_DREAL_ENABLED=true
# Disabled by default; flip on only when a Certora CLI + license is wired in.
FORMAL_METHODS_CERTORA_ENABLED=false

# Per-analyzer paths and tunables (relative to the cloned PR worktree).
PROPTEST_TEST_TARGET=proptest_props
VERUS_PROOF_CRATE_DIR=packages/contract/om-core/proofs/verus
DREAL_QUERIES_DIR=packages/contract/om-core/proofs/dreal
DREAL_PRECISION=0.001
CERTORA_CONF_DIR=packages/contract/om-core/proofs/certora/conf
